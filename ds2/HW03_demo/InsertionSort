#include <iostream>
#include<vector>
#include<fstream>
#include<cstdlib>
#include<ctime>
#include<chrono>
using namespace std;
using namespace std::chrono;

void InsertionSort(vector<int>& arr){
    int n = arr.size();
    for(int i = 1;i < n;i++){
        int k = arr[i];
        int j = i - 1;
        while(j >= 0 && arr[j] > k){
            arr[j + 1] = arr[j];
            j--;
        }
        arr[j + 1] = k;
    }
}

int main(){
    ofstream fout("sort.csv");
    srand(time(NULL));
    
    for(int n = 10;n <= 100000;n *= 10){
        vector<int> arr;
        for(int i = 0;i < n;i++)
            arr.push_back(rand() % 50000 + 1);
            
        auto start = high_resolution_clock::now();
        InsertionSort(arr);
        auto end = high_resolution_clock::now();
        duration<double> elapsed = end - start;
        fout << elapsed.count() << endl;
        cout << n << endl;
    }
    fout.close();
    cout << "done" << endl;
    return 0;
}
